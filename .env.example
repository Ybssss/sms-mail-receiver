# Required: Hero-SMS API key (hero-sms.com dashboard)
HERO_SMS_API_KEY=your_hero_sms_api_key

# Required: Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Required on Render: public URL (no trailing slash)
WEBAPP_URL=

# Optional: bot username without @
TELEGRAM_BOT_USERNAME=

# Optional: protect webhook endpoint
WEBHOOK_SECRET=

# Hero-SMS API base URL
HERO_SMS_BASE_URL=https://hero-sms.com/api/v1

# Default order values for /order and web form
DEFAULT_EMAIL_SITE=telegram.com
DEFAULT_EMAIL_DOMAIN=gmail.com

# Fast poll for waiting emails (ms) — default 2000 = 2 seconds
POLL_INTERVAL_MS=2000

# Render keep-alive self-ping (ms) — default 600000 = 10 minutes
KEEPALIVE_INTERVAL_MS=600000

PORT=3000
DATABASE_PATH=./data/mail.db

# ── Gems & dynamic exchange rate ─────────────────────────────────────────────
# At USD/MYR = 4 → 1 MYR = 10,000 gems. Scales automatically when USD/MYR moves.
BASE_USD_MYR=4
BASE_GEMS_PER_MYR=10000
EXCHANGE_RATE_CACHE_MS=3600000
ORDER_MARKUP_PERCENT=20
MIN_ORDER_GEMS=1000
DEFAULT_ORDER_COST_MYR=0.50
MIN_TOPUP_MYR=5

# ── Billplz (FPX, card, TnG, GrabPay → settles to your bank) ────────────────
BILLPLZ_API_KEY=
BILLPLZ_COLLECTION_ID=
BILLPLZ_X_SIGNATURE=
BILLPLZ_API_URL=https://www.billplz.com/api

# ── Telegram Stars (in-bot payments) ───────────────────────────────────────────
TELEGRAM_PAYMENT_PROVIDER_TOKEN=
MYR_PER_STAR=0.052

# ── Manual top-up (money goes directly to your TnG / bank) ────────────────────
MANUAL_TNG_PHONE=
MANUAL_TNG_QR_URL=
MANUAL_BANK_NAME=
MANUAL_BANK_ACCOUNT=
MANUAL_BANK_HOLDER=
MANUAL_BANK_QR_URL=

# Comma-separated Telegram user IDs allowed to /approve manual payments
ADMIN_TELEGRAM_IDS=
